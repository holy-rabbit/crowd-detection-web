# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# FFmpeg Path (optional, will auto-detect if not set)
FFMPEG_PATH=/usr/bin/ffmpeg

# Video Processing
MAX_VIDEO_SIZE_MB=500
ALLOWED_EXTENSIONS=mp4,avi,mov,mkv,flv

# Crowd Detection Model
MODEL_NAME=yolov5s
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# SORT Tracking Parameters
TRACKER_MAX_AGE=20
TRACKER_MIN_HITS=3
TRACKER_IOU_THRESHOLD=0.3

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000